# ─────────────────────────────────────────────────────────────────
# Telegram Coupon Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.
# ─────────────────────────────────────────────────────────────────

# Required
BOT_TOKEN=your_bot_token_from_botfather
ADMIN_IDS=123456789,987654321        # Comma-separated Telegram user IDs

# Payment
UPI_ID=yourname@upi

# Optional — leave blank for polling (local dev)
# On Railway, set to your Railway public domain:
#   e.g. https://my-app.up.railway.app
WEBHOOK_URL=

# Railway sets PORT automatically; default 8443 for local webhook testing
PORT=8443

# Database (SQLite path — relative to project root)
DATABASE_URL=data/bot.db

# Bot branding
BOT_NAME=CouponBot
CURRENCY_SYMBOL=₹

# Minutes before a pending order expires
PAYMENT_TIMEOUT_MINUTES=30

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Maintenance mode
MAINTENANCE_MODE=false
